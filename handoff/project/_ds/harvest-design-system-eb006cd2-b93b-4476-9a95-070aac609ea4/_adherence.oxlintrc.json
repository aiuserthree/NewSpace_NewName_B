{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "assets/**",
              "components/actions/**",
              "components/brand/**",
              "components/content/**",
              "components/feedback/**",
              "components/forms/**",
              "components/media/**",
              "ui_kits/space-name-contest/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Pretendard|Newsreader|Gowun Batang))/i]",
        "message": "Font not provided by the design system. Available: Pretendard, Newsreader, Gowun Batang."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|leftIcon|rightIcon|fullWidth|disabled|type|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, leftIcon, rightIcon, fullWidth, disabled, type, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FeatureCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|body|linkText|href|surface|elevated|children|key|ref|className|style|children)$/]",
        "message": "<FeatureCard> doesn't accept that prop. Declared props: icon, title, body, linkText, href, surface, elevated, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='FeatureCard'] > JSXAttribute[name.name='surface'] > Literal[value!=/^(?:card|canvas)$/]",
        "message": "<FeatureCard> surface must be one of 'card' | 'canvas'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FeatureSplit'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|title|body|ctaLabel|onCta|reverse|media|gap|children|key|ref|className|style|children)$/]",
        "message": "<FeatureSplit> doesn't accept that prop. Declared props: eyebrow, title, body, ctaLabel, onCta, reverse, media, gap, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='HeroWash'] > JSXAttribute > JSXIdentifier[name!=/^(?:intensity|key|ref|className|style|children)$/]",
        "message": "<HeroWash> doesn't accept that prop. Declared props: intensity."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|strokeWidth|color|title|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, strokeWidth, color, title."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|leftIcon|helper|error|required|disabled|style|inputStyle|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, leftIcon, helper, error, required, disabled, style, inputStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='LogoCircle'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|label|children|key|ref|className|style|children)$/]",
        "message": "<LogoCircle> doesn't accept that prop. Declared props: size, label, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|href|hasMenu|key|ref|className|style|children)$/]",
        "message": "<NavLink> doesn't accept that prop. Declared props: label, href, hasMenu."
      },
      {
        "selector": "JSXOpeningElement[name.name='Notice'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|title|icon|action|onClose|children|key|ref|className|style|children)$/]",
        "message": "<Notice> doesn't accept that prop. Declared props: tone, title, icon, action, onClose, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Notice'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:info|accent|success)$/]",
        "message": "<Notice> tone must be one of 'info' | 'accent' | 'success'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PreviewCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:tilt|padded|children|key|ref|className|style|children)$/]",
        "message": "<PreviewCard> doesn't accept that prop. Declared props: tilt, padded, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeading'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|title|subtitle|align|titleSize|as|key|ref|className|style|children)$/]",
        "message": "<SectionHeading> doesn't accept that prop. Declared props: eyebrow, title, subtitle, align, titleSize, as."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeading'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:center|left)$/]",
        "message": "<SectionHeading> align must be one of 'center' | 'left'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeading'] > JSXAttribute[name.name='titleSize'] > Literal[value!=/^(?:heading-lg|title|display)$/]",
        "message": "<SectionHeading> titleSize must be one of 'heading-lg' | 'title' | 'display'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StepIndicator'] > JSXAttribute > JSXIdentifier[name!=/^(?:steps|current|key|ref|className|style|children)$/]",
        "message": "<StepIndicator> doesn't accept that prop. Declared props: steps, current."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|size|icon|children|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: tone, size, icon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|accent|solid|wash|outline)$/]",
        "message": "<Tag> tone must be one of 'neutral' | 'accent' | 'solid' | 'wash' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Tag> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:href|withArrow|size|children|key|ref|className|style|children)$/]",
        "message": "<TextLink> doesn't accept that prop. Declared props: href, withArrow, size, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextLink'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<TextLink> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TrustLogoRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|logos|key|ref|className|style|children)$/]",
        "message": "<TrustLogoRow> doesn't accept that prop. Declared props: label, logos."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
